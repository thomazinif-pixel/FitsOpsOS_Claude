generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum Cargo {
  COO
  MANAGER
  ANALYST
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum Categoria {
  CRESCIMENTO
  EFICIENCIA
  QUALIDADE
  EXPERIENCIA
}

enum Unidade {
  PERCENTUAL
  DIAS
  REAIS
  QUANTIDADE
}

enum Direcao {
  UP
  DOWN
}

enum StatusKPI {
  GREEN
  YELLOW
  RED
}

enum Tendencia {
  UP
  DOWN
  STABLE
}

enum StatusPlano {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model User {
  id           String     @id @default(cuid())
  nome         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         Role       @default(VIEWER)
  cargo        Cargo      @default(ANALYST)
  status       UserStatus @default(ACTIVE)
  ultimoLogin  DateTime?  @map("ultimo_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  kpisOwned KPI[] @relation("KpiOwner")

  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  kpis KPI[]

  @@map("departments")
}

model KPI {
  id           String     @id @default(cuid())
  nome         String
  descricao    String?
  categoria    Categoria
  unidade      Unidade
  metaAnual    Float      @map("meta_anual")
  metaMensal   Float      @map("meta_mensal")
  direcao      Direcao
  peso         Float      @default(1.0)
  ativo        Boolean    @default(true)
  ownerId      String?    @map("owner_id")
  departmentId String?    @map("department_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  owner      User?       @relation("KpiOwner", fields: [ownerId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  values      KPIValue[]
  analyses    KPIAnalysis[]
  actionPlans ActionPlan[]

  @@map("kpis")
}

model KPIValue {
  id             String   @id @default(cuid())
  kpiId          String   @map("kpi_id")
  mes            Int
  ano            Int
  valorRealizado Float    @map("valor_realizado")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, mes, ano])
  @@map("kpi_values")
}

model KPIAnalysis {
  id                    String    @id @default(cuid())
  kpiId                 String    @map("kpi_id")
  mes                   Int
  ano                   Int
  percentualAtingimento Float     @map("percentual_atingimento")
  status                StatusKPI
  tendencia             Tendencia
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, mes, ano])
  @@map("kpi_analyses")
}

model ActionPlan {
  id              String      @id @default(cuid())
  kpiId           String      @map("kpi_id")
  descricao       String
  responsavel     String
  prazo           DateTime
  status          StatusPlano @default(PENDENTE)
  impactoEstimado String?     @map("impacto_estimado")
  aiGenerated     Boolean     @default(false) @map("ai_generated")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@map("action_plans")
}
